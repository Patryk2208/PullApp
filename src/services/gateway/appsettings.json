{
  "ReverseProxy": {
    "Routes": {
      "accounts-route": {
        "ClusterId": "accounts-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "trip-planner-route": {
        "ClusterId": "trip-planner-cluster",
        "Match": {
          "Path": "/api/route/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "accounts-cluster": {
        "Destinations": {
          "1": {
            "Address": "http://accounts-api:8080"
          }
        }
      },
      "trip-planner-cluster": {
        "Destinations": {
          "1": {
            "Address": "http://trip-planner-api:8080"
          }
        }
      }
    }
  }
}
