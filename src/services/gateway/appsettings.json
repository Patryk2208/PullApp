{
  "Jwt": {
    "Issuer": "pullapp",
    "Audience": "pullapp",
    "Key": "PLACEHOLDER"
  },
  "ReverseProxy": {
    "Routes": {
      "accounts-route": {
        "ClusterId": "accounts-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "trip-planner-route": {
        "ClusterId": "trip-planner-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/route/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/sse/notifications"
        }
      },
      "driver-tracker-route": {
        "ClusterId": "driver-tracker-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/ws/driver-tracker"
        }
      }
    },
    "Clusters": {
      "accounts-cluster": {
        "Destinations": {
          "1": { "Address": "http://accounts:80" }
        }
      },
      "trip-planner-cluster": {
        "Destinations": {
          "1": { "Address": "http://trip-planner:80" }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "1": { "Address": "http://notifications:80" }
        }
      },
      "driver-tracker-cluster": {
        "Destinations": {
          "1": { "Address": "http://driver-tracker:80" }
        }
      }
    }
  }
}
