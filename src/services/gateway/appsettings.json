{
  "Jwt": {
    "Issuer": "pullapp",
    "Audience": "pullapp",
    "Key": "PLACEHOLDER"
  },
  "ReverseProxy": {
    "Routes": {
      "accounts-route": {
        "ClusterId": "accounts-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "trip-planner-route": {
        "ClusterId": "trip-planner-cluster",
        "Match": {
          "Path": "/api/route/{**catch-all}"
        },
        "AuthorizationPolicy": "default",
        "Transforms": [
          {
            "PathRemovePrefix": "/api/route"
          }
        ]
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/sse/notifications"
        },
        "Transforms": [
          {
            "PathSet": "/stream"
          }
        ]
      },
      "driver-tracker-position-route": {
        "ClusterId": "driver-tracker-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/tracker/position/{routeId}"
        },
        "Transforms": [
          {
            "PathPattern": "/position/{routeId}"
          }
        ]
      },
      "driver-tracker-track-route": {
        "ClusterId": "driver-tracker-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/ws/driver-tracker/{routeId}"
        },
        "Transforms": [
          {
            "PathPattern": "/track/{routeId}"
          }
        ]
      }
    },
    "Clusters": {
      "accounts-cluster": {
        "Destinations": {
          "1": {
            "Address": "http://accounts-api:8080"
          }
        }
      },
      "trip-planner-cluster": {
        "Destinations": {
          "1": {
            "Address": "http://trip-planner:8080"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "1": {
            "Address": "http://notifications:80"
          }
        }
      },
      "driver-tracker-cluster": {
        "Destinations": {
          "1": {
            "Address": "http://driver-tracker:80"
          }
        }
      }
    }
  }
}