@TripPlanner.Api_HostAddress = http://localhost:5000

###
# DRIVER — REGISTER ROUTE
//POST {{TripPlanner.Api_HostAddress}}/api/driver/route
POST {{TripPlanner.Api_HostAddress}}}/api/driver/route
Content-Type: application/json
X-User-Id: 11111111-1111-1111-1111-111111111111

{
  "start": {
    "lat": 52.2297,
    "lng": 21.0122
  },
  "end": {
    "lat": 52.25,
    "lng": 21.05
  }
}

###
# DRIVER — MODIFY ROUTE
PUT {{TripPlanner.Api_HostAddress}}/api/driver/route
Content-Type: application/json
X-User-Id: 11111111-1111-1111-1111-111111111111

{
  "start": {
    "lat": 52.23,
    "lng": 21.01
  },
  "end": {
    "lat": 52.24,
    "lng": 21.08
  }
}

###
# DRIVER — CANCEL ROUTE
DELETE {{TripPlanner.Api_HostAddress}}/api/driver/route
X-User-Id: 11111111-1111-1111-1111-111111111111

###
# PASSENGER — CREATE ROUTE REQUEST
POST {{TripPlanner.Api_HostAddress}}/api/passenger/route-requests
Content-Type: application/json
X-User-Id: 22222222-2222-2222-2222-222222222222

{
  "start": {
    "lat": 52.2297,
    "lng": 21.0122
  },
  "end": {
    "lat": 52.24,
    "lng": 21.04
  },
  "constraints": {
    "maxDetourKm": 5,
    "maxResults": 3
  }
}

###
# PASSENGER — SELECT ROUTE
POST {{TripPlanner.Api_HostAddress}}/api/passenger/route-requests/11111111-1111-1111-1111-111111111111/select
Content-Type: application/json
X-User-Id: 22222222-2222-2222-2222-222222222222

{
  "driverRouteId": "33333333-3333-3333-3333-333333333333"
}

###
# PASSENGER — CANCEL ROUTE REQUEST
DELETE {{TripPlanner.Api_HostAddress}}/api/passenger/route-requests/11111111-1111-1111-1111-111111111111
X-User-Id: 22222222-2222-2222-2222-222222222222

###
# DRIVER — CONFIRM REQUEST
POST {{TripPlanner.Api_HostAddress}}/api/driver/requests/11111111-1111-1111-1111-111111111111/confirmation
Content-Type: application/json
X-User-Id: 11111111-1111-1111-1111-111111111111

{
  "accepted": true
}

###
# DRIVER — ARRIVED
POST {{TripPlanner.Api_HostAddress}}/api/driver/rides/11111111-1111-1111-1111-111111111111/arrived
X-User-Id: 11111111-1111-1111-1111-111111111111

###
# DRIVER — START RIDE
POST {{TripPlanner.Api_HostAddress}}/api/driver/rides/11111111-1111-1111-1111-111111111111/start
X-User-Id: 11111111-1111-1111-1111-111111111111

###
# PASSENGER — START RIDE
POST {{TripPlanner.Api_HostAddress}}/api/passenger/rides/11111111-1111-1111-1111-111111111111/start
X-User-Id: 22222222-2222-2222-2222-222222222222

###
# PASSENGER — CONFIRM PRICE
POST {{TripPlanner.Api_HostAddress}}/api/passenger/rides/11111111-1111-1111-1111-111111111111/confirm-price
X-User-Id: 22222222-2222-2222-2222-222222222222

###
# DRIVER — COMPLETE RIDE
POST {{TripPlanner.Api_HostAddress}}/api/driver/rides/11111111-1111-1111-1111-111111111111/complete
Content-Type: application/json
X-User-Id: 11111111-1111-1111-1111-111111111111

{
  "dropoffPoint": {
    "lat": 52.24,
    "lng": 21.05
  }
}

###
# DRIVER — CANCEL RIDE
POST {{TripPlanner.Api_HostAddress}}/api/driver/rides/11111111-1111-1111-1111-111111111111/cancel
Content-Type: application/json
X-User-Id: 11111111-1111-1111-1111-111111111111

{
  "reason": "driver unavailable"
}

###
# PASSENGER — CANCEL RIDE
POST {{TripPlanner.Api_HostAddress}}/api/passenger/rides/11111111-1111-1111-1111-111111111111/cancel
Content-Type: application/json
X-User-Id: 22222222-2222-2222-2222-222222222222

{
  "reason": "changed plans"
}