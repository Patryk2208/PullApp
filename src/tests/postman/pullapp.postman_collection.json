    {
      "name": "Notifications — Direct",
      "description": "Hit notifications service directly (bypass gateway).\nUses `X-User-Id` header instead of JWT.\n\nEndpoints:\n  GET  /stream          — SSE event stream (keep-alive, long-lived connection)\n  POST /devices/register — register FCM push token\n  GET  /health",
      "item": [
        {
          "name": "SSE Stream",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-User-Id", "value": "{{userId}}" },
              { "key": "Accept",    "value": "text/event-stream" }
            ],
            "url": {
              "raw": "{{notifications_url}}/stream",
              "host": ["{{notifications_url}}"],
              "path": ["stream"]
            },
            "description": "Opens an SSE connection for the user. Server sends events in the format:\n  event: <type>\\ndata: <json>\\n\\n\nKeep-alive comment lines are sent every 15 s.\nClient reconnect delay is 3 s (set via `retry: 3000` on connect).\n\nNote: Postman does not render SSE natively — use curl or a browser EventSource for live testing:\n  curl -N -H 'X-User-Id: <uuid>' http://localhost:5003/stream\n\n401 Unauthorized — missing X-User-Id header"
          },
          "response": []
        },
        {
          "name": "Register Device Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{notifications_url}}/devices/register",
              "host": ["{{notifications_url}}"],
              "path": ["devices", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"token\": \"fcm-device-token-here\",\n  \"platform\": \"android\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Upserts an FCM push token for a user.\n`platform` is typically `android` or `ios`.\n\n204 No Content — token stored\n400 Bad Request — missing fields"
          },
          "response": []
        },
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{notifications_url}}/health",
              "host": ["{{notifications_url}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Driver Tracker — Direct",
      "description": "Hit driver-tracker service directly (bypass gateway).\nUses `X-User-Id` header where required.\n\nEndpoints:\n  POST /position/:routeId — driver pushes a location update (HTTP polling)\n  GET  /track/:routeId    — WebSocket stream of driver positions for a route\n  GET  /health",
      "item": [
        {
          "name": "Update Driver Position",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{driver_tracker_url}}/position/{{routeId}}",
              "host": ["{{driver_tracker_url}}"],
              "path": ["position", "{{routeId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lat\": 52.2310,\n  \"lng\": 21.0150,\n  \"timestamp\": 1748600000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Driver pushes their current location for the given route.\nStored in Redis; subscribed WebSocket clients receive the update immediately.\n\n204 No Content — position stored\n400 Bad Request — invalid routeId or missing fields"
          },
          "response": []
        },
        {
          "name": "Track Route (WebSocket)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Connection", "value": "Upgrade" },
              { "key": "Upgrade",    "value": "websocket" }
            ],
            "url": {
              "raw": "{{driver_tracker_url}}/track/{{routeId}}",
              "host": ["{{driver_tracker_url}}"],
              "path": ["track", "{{routeId}}"]
            },
            "description": "WebSocket endpoint — upgrades the HTTP connection to WS.\nPassengers connect here to receive real-time driver position updates for a route.\n\nPostman supports WebSocket requests via New → WebSocket Request (separate from the collection HTTP flow). Use ws://localhost:5004/track/<routeId> there.\n\nAlternatively with wscat:\n  wscat -c ws://localhost:5004/track/<routeId>"
          },
          "response": []
        },
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{driver_tracker_url}}/health",
              "host": ["{{driver_tracker_url}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
