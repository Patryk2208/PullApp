# Environment Variables for PullApp Infrastructure
# Copy this file to src/infrastructure/.env

# ═══════════════════════════════════════════════════════════════
# RabbitMQ Configuration
# ═══════════════════════════════════════════════════════════════
RABBITMQ_USER=pullapp
RABBITMQ_PASS=pullapp-secret

# ═══════════════════════════════════════════════════════════════
# PostgreSQL - Trip Planner Database
# ═══════════════════════════════════════════════════════════════
TRIP_PLANNER_POSTGRES_DB=trip-planner
TRIP_PLANNER_POSTGRES_USER=pullapp
TRIP_PLANNER_POSTGRES_PASSWORD=pullapp-secret

# ═══════════════════════════════════════════════════════════════
# PostgreSQL - Accounts Database
# ═══════════════════════════════════════════════════════════════
ACCOUNTS_POSTGRES_DB=accounts
ACCOUNTS_POSTGRES_USER=pullapp
ACCOUNTS_POSTGRES_PASSWORD=pullapp-secret

# ═══════════════════════════════════════════════════════════════
# Redis Cache
# ═══════════════════════════════════════════════════════════════
REDIS_PASSWORD=redis-secret

# ═══════════════════════════════════════════════════════════════
# For Running route-calc Locally (Not in Container)
# ═══════════════════════════════════════════════════════════════
COMPUTE_QUEUE_PASSWORD=pullapp-secret
TRIP_PLANNER_DB_PASSWORD=pullapp-secret
CACHE_PASSWORD=redis-secret
